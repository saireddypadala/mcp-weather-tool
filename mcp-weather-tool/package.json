{
  "name": "mcp-weather-tool",
  "displayName": "mcp-weather-tool",
  "description": "MCP Weather Tool VS Code Extension",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
